generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String          @id @default(cuid())
  email                String          @unique
  password             String
  firstName            String
  lastName             String
  role                 String          @default("user") // "user" | "admin"
  
  // Flattened address fields
  addressLine1         String?
  addressCity          String?
  addressState         String?
  addressPostalCode    String?
  addressCountry       String?

  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  
  orders               Order[]
  bespokeDesigns       BespokeDesign[]

  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String
  price         Float
  category      String   // "Rings" | "Necklaces" | "Earrings" | "Bracelets" | "Bespoke"
  images        String[]
  stock         Int      @default(0)
  material      String?  // "18K Gold" | "14K Gold" | "Platinum" | "Silver" | "Brass"
  plating       String   @default("None") // "18K Gold Plated" | "Rose Gold Plated" | "Rhodium" | "None"
  isAntiTarnish Boolean  @default(false)
  gemstone      String?
  featured      Boolean  @default(false)

  orderItems    OrderItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  totalAmount     Float
  currency        String      @default("INR")
  
  // Flattened shipping address
  shippingLine1   String?
  shippingCity    String?
  shippingState   String?
  shippingPostalCode String?
  shippingCountry String?

  paymentId       String?
  paymentGateway  String?     // "Razorpay" | "Stripe"
  paymentStatus   String      @default("pending") // "pending" | "completed" | "failed" | "refunded"
  orderStatus     String      @default("placed")  // "placed" | "processing" | "shipped" | "delivered" | "cancelled"

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id])
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  quantity        Int
  priceAtPurchase Float
}

model BespokeDesign {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  designImage  String
  description  String
  material     String
  gemstones    String   @default("None")
  budget       String
  timeline     String   @default("Flexible")
  status       String   @default("Pending Review")
  adminNotes   String   @default("")
  quoteAmount  Float    @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}
